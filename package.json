{
  "name": "dayglass-usage",
  "version": "0.3.0",
  "private": true,
  "description": "Glass-style Windows desktop app usage tracker with a 6 AM day boundary.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "dayglass.usage",
    "productName": "DayGlass",
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/after-pack.js",
    "files": [
      "src/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/assets/app-icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "ws": "^8.20.1"
  }
}
